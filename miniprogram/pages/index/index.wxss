/* pages/index/index.wxss */

.page { min-height: 100vh; padding-bottom: 60rpx; }

/* Header */
.header {
  background: #fff; padding: 20rpx 30rpx;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.06);
  position: sticky; top: 0; z-index: 10;
}
.title { font-size: 36rpx; font-weight: 700; color: #1a1a2e; display: block; margin-bottom: 16rpx; }

/* Search */
.search-bar { position: relative; }
.search-row { display: flex; gap: 12rpx; align-items: center; }
.search-input {
  flex: 1; padding: 16rpx 24rpx; border: 2rpx solid #e0e0e0;
  border-radius: 12rpx; font-size: 28rpx; background: #fff;
}
.search-btn {
  background: #4a90d9; color: #fff; font-size: 26rpx; font-weight: 600;
  padding: 16rpx 28rpx; border-radius: 12rpx; white-space: nowrap;
}
.search-btn:active { opacity: 0.7; }
.search-dropdown {
  position: absolute; top: 100%; left: 0; right: 0; background: #fff;
  border: 1rpx solid #e0e0e0; border-radius: 12rpx;
  box-shadow: 0 8rpx 24rpx rgba(0,0,0,0.1); max-height: 400rpx; overflow-y: auto; z-index: 20;
}
.search-item {
  padding: 20rpx 24rpx; display: flex; gap: 20rpx; border-bottom: 1rpx solid #f0f0f0;
}
.search-item:active { background: #f5f8ff; }
.fund-code { font-weight: 700; color: #4a90d9; min-width: 120rpx; }
.fund-name { color: #666; font-size: 26rpx; flex: 1; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }

/* Loading */
.loading {
  display: flex; flex-direction: column; align-items: center; padding: 160rpx 0; color: #999;
}
.spinner {
  width: 60rpx; height: 60rpx; border: 4rpx solid #e0e0e0; border-top-color: #4a90d9;
  border-radius: 50%; animation: spin 0.8s linear infinite; margin-bottom: 24rpx;
}
@keyframes spin { to { transform: rotate(360deg); } }

/* Landing */
.landing {
  display: flex; flex-direction: column; align-items: center; padding: 160rpx 40rpx 0;
}
.landing-title { font-size: 44rpx; font-weight: 700; color: #1a1a2e; margin-bottom: 32rpx; }
.landing-desc { font-size: 28rpx; color: #888; line-height: 1.8; text-align: center; }

/* Favorites list */
.fav-list { margin-top: 40rpx; }
.fav-list-title { font-size: 28rpx; font-weight: 600; color: #666; display: block; margin-bottom: 16rpx; }
.fav-item {
  display: flex; align-items: center; background: #fff; border-radius: 12rpx;
  padding: 20rpx 24rpx; margin-bottom: 10rpx; box-shadow: 0 1rpx 3rpx rgba(0,0,0,0.04);
}
.fav-item:active { background: #f5f8ff; }
.fav-item-left { flex: 1; }
.fav-item-code { font-weight: 700; color: #4a90d9; font-size: 28rpx; display: block; }
.fav-item-name { font-size: 24rpx; color: #666; margin-top: 4rpx; display: block; }
.fav-item-type { font-size: 20rpx; color: #aaa; background: #f0f0f0; padding: 4rpx 12rpx; border-radius: 8rpx; margin-right: 12rpx; }
.fav-item-del { font-size: 28rpx; color: #ccc; padding: 8rpx; }
.fav-item-del:active { color: #e74c3c; }

/* Fund Bar */
.fund-bar { display: flex; align-items: center; justify-content: space-between; padding: 24rpx 30rpx; }
.fund-bar-left { display: flex; align-items: center; gap: 16rpx; flex-wrap: wrap; flex: 1; }
.fund-bar-name { font-size: 34rpx; font-weight: 600; }
.fund-bar-code {
  background: #e8f0fe; color: #4a90d9; padding: 4rpx 16rpx;
  border-radius: 8rpx; font-size: 24rpx;
}
.badge {
  background: #e8f0fe; color: #4a90d9; padding: 4rpx 20rpx;
  border-radius: 20rpx; font-size: 22rpx; font-weight: 600;
}
.scale-badge { font-size: 22rpx; color: #888; }
.date-badge { font-size: 22rpx; color: #aaa; }

/* Favorite button */
.fav-btn { font-size: 48rpx; padding: 8rpx 16rpx; }
.fav-btn.favorited { color: #f39c12; }

/* Period Tabs */
.period-tabs { display: flex; gap: 8rpx; padding: 0 30rpx 20rpx; }
.tab {
  padding: 10rpx 24rpx; border: 1rpx solid #d0d0d0; border-radius: 10rpx;
  font-size: 24rpx; color: #666; background: #fff;
}
.tab.active { background: #4a90d9; color: #fff; border-color: #4a90d9; }

/* Metric Cards */
.cards { display: flex; flex-wrap: wrap; gap: 16rpx; padding: 0 30rpx 24rpx; }
.card {
  background: #fff; border-radius: 16rpx; padding: 24rpx; flex: 1 1 40%;
  min-width: 280rpx; box-shadow: 0 2rpx 6rpx rgba(0,0,0,0.04);
}
.card.highlight { border-left: 4rpx solid #e74c3c; }
.card-label { font-size: 22rpx; color: #888; display: block; margin-bottom: 8rpx; }
.card-value { font-size: 40rpx; font-weight: 700; display: block; }
.card-value.positive { color: #27ae60; }
.card-value.negative { color: #e74c3c; }
.card-sub { font-size: 20rpx; color: #aaa; display: block; margin-top: 6rpx; }

/* Section */
.section { padding: 0 30rpx 24rpx; }
.section-title { font-size: 28rpx; font-weight: 600; color: #666; display: block; margin-bottom: 16rpx; }

/* DCA */
.dca-section { padding: 0 30rpx 24rpx; }

/* DCA 参数输入 */
.dca-params { display: flex; align-items: center; gap: 12rpx; margin-bottom: 20rpx; }
.dca-param { display: flex; align-items: center; background: #fff; border-radius: 10rpx; padding: 8rpx 16rpx; box-shadow: 0 1rpx 3rpx rgba(0,0,0,0.03); }
.param-label { font-size: 22rpx; color: #888; margin-right: 8rpx; }
.param-input { width: 120rpx; font-size: 28rpx; font-weight: 700; text-align: center; border: 1rpx solid #e0e0e0; border-radius: 6rpx; padding: 4rpx 8rpx; }
.param-unit { font-size: 22rpx; color: #888; margin-left: 4rpx; }
.dca-btn { background: #4a90d9; color: #fff; font-size: 26rpx; padding: 12rpx 24rpx; border-radius: 10rpx; }
.dca-btn:active { opacity: 0.7; }

.dca-summary { display: flex; flex-wrap: wrap; gap: 12rpx; margin-bottom: 16rpx; }
.dca-stat {
  background: #fff; border-radius: 12rpx; padding: 20rpx 24rpx;
  flex: 1 1 28%; min-width: 200rpx; box-shadow: 0 1rpx 3rpx rgba(0,0,0,0.03);
}
.dca-label { font-size: 20rpx; color: #888; display: block; margin-bottom: 4rpx; }
.dca-value { font-size: 30rpx; font-weight: 700; color: #333; display: block; }
.disclaimer { font-size: 20rpx; color: #aaa; display: block; text-align: center; margin-top: 20rpx; }

/* DCA explain */
.dca-explain {
  font-size: 26rpx; color: #555; line-height: 1.8;
  background: #fafbfc; border-radius: 12rpx; padding: 20rpx; margin-bottom: 20rpx;
}
.dca-explain .bold, .bold { font-weight: 700; color: #333; }

/* DCA 数据不足警告 */
.dca-warning {
  font-size: 24rpx; color: #e67e22; line-height: 1.6;
  background: #fef9f3; border-left: 4rpx solid #e67e22;
  border-radius: 8rpx; padding: 16rpx 20rpx; margin-bottom: 16rpx;
}

/* DCA cost compare */
.dca-cost-compare {
  background: #fff; border-radius: 12rpx; padding: 20rpx; margin: 16rpx 0;
  box-shadow: 0 1rpx 3rpx rgba(0,0,0,0.03);
}
.compare-label { font-size: 24rpx; font-weight: 600; color: #666; display: block; margin-bottom: 12rpx; }
.compare-row { display: flex; align-items: center; gap: 16rpx; margin-bottom: 8rpx; }
.compare-item { font-size: 26rpx; color: #555; flex: 1; text-align: center; }
.compare-vs { font-size: 22rpx; color: #bbb; }
.compare-hint { font-size: 24rpx; display: block; margin-top: 8rpx; line-height: 1.6; }
.compare-hint.positive { color: #27ae60; }
.compare-hint.negative { color: #e74c3c; }

/* DCA vs Lump Sum */
.dca-vs-lump {
  background: #fff; border-radius: 12rpx; padding: 20rpx; margin: 16rpx 0;
  box-shadow: 0 1rpx 3rpx rgba(0,0,0,0.03);
  font-size: 26rpx; color: #555; line-height: 1.8;
}
.vs-row { display: flex; gap: 16rpx; margin-top: 16rpx; }
.vs-col {
  flex: 1; background: #f8f9fa; border-radius: 10rpx; padding: 16rpx; text-align: center;
}
.vs-label { font-size: 22rpx; color: #888; display: block; margin-bottom: 4rpx; }
.vs-value { font-size: 32rpx; font-weight: 700; display: block; }
.vs-value.positive { color: #27ae60; }
.vs-sub { font-size: 20rpx; color: #aaa; display: block; margin-top: 4rpx; }
.dca-stat.highlight-stat { background: #f0f7ff; border-left: 4rpx solid #4a90d9; }

/* Holdings Table */
.holdings-table { background: #fff; border-radius: 16rpx; overflow: hidden; box-shadow: 0 1rpx 3rpx rgba(0,0,0,0.04); }
.holdings-header { display: flex; background: #f8f9fa; padding: 20rpx 24rpx; border-bottom: 1rpx solid #eee; }
.holdings-row { display: flex; padding: 18rpx 24rpx; border-bottom: 1rpx solid #f0f0f0; }
.holdings-row:last-child { border-bottom: none; }
.h-col { font-size: 22rpx; font-weight: 600; color: #666; }
.code-col { width: 160rpx; font-size: 24rpx; }
.name-col { flex: 1; font-size: 24rpx; }
.weight-col { width: 120rpx; text-align: right; font-size: 24rpx; color: #333; }

/* Footer */
.footer-disclaimer {
  font-size: 22rpx; color: #bbb; display: block; text-align: center; padding: 24rpx;
}

/* Modal */
.modal-mask {
  position: fixed; top: 0; left: 0; right: 0; bottom: 0;
  background: rgba(0,0,0,0.4); z-index: 100;
  display: flex; align-items: center; justify-content: center;
}
.modal-box {
  background: #fff; border-radius: 20rpx; width: 85%; max-width: 640rpx;
  max-height: 80vh; padding: 40rpx; overflow-y: auto;
}
.modal-title { font-size: 32rpx; font-weight: 700; color: #1a1a2e; display: block; margin-bottom: 20rpx; }
.modal-body { font-size: 26rpx; color: #555; line-height: 1.8; white-space: pre-wrap; }
.modal-close-btn {
  display: block; margin-top: 30rpx; text-align: center; padding: 16rpx;
  background: #4a90d9; color: #fff; border-radius: 12rpx; font-size: 28rpx;
}
